---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getPosts } from "../../lib/wordpress.js";

const posts = await getPosts({ perPage: 12 });
---

<BaseLayout
  title="블로그 | Pet Nutrition Guide"
  description="WordPress에서 가져온 반려동물 영양 정보 블로그 글 목록"
  path="/blog"
>
  <main>
    <section class="page-hero">
      <div class="container">
        <div>
          <p class="eyebrow">Blog</p>
          <h1>반려동물 영양 블로그</h1>
          <p>WordPress REST API에서 가져온 최신 글을 정적 페이지로 보여줍니다.</p>
        </div>
        <aside class="quick-box">
          <strong>운영 방식</strong>
          WordPress 관리자에서 글을 작성한 뒤 Astro를 다시 빌드하면 이 목록에 반영됩니다.
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container">
        {posts.length > 0 ? (
          <div class="grid three">
            {posts.map((post) => <BlogCard post={post} />)}
          </div>
        ) : (
          <div class="empty-state">
            아직 등록된 글이 없습니다. WordPress 관리자에서 글을 작성하고 공개한 뒤 다시 빌드해 주세요.
          </div>
        )}
      </div>
    </section>
  </main>
</BaseLayout>
