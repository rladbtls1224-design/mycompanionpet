---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogCard from "../components/BlogCard.astro";
import { getPostCategories, getPosts } from "../lib/wordpress.js";

const posts = await getPosts({ perPage: 24 });
const catPosts = posts
  .filter((post) => getPostCategories(post).includes("고양이 영양"))
  .slice(0, 9);
---

<BaseLayout
  title="고양이 영양 기초 | Pet Nutrition Guide"
  description="고양이 보호자를 위한 기초 영양 정보, 수분 섭취, 사료 선택, 안전한 간식 급여 기준과 관련 블로그 글"
  path="/cat-nutrition"
>
  <main>
    <section class="page-hero">
      <div class="container">
        <div>
          <p class="eyebrow">Cat Nutrition</p>
          <h1>고양이 영양 기초</h1>
          <p>고양이는 육식 중심의 영양이 필요한 동물입니다. 주식과 간식을 구분하고, 수분 섭취와 건강 상태를 함께 살피는 것이 중요합니다.</p>
        </div>
        <aside class="quick-box">
          <strong>핵심 체크</strong>
          고양이용 주식인지, 생활 단계에 맞는지, 물 섭취 환경이 충분한지 먼저 확인하세요.
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container content-layout">
        <article class="article">
          <h2>고양이 식단에서 먼저 볼 것</h2>
          <p>고양이는 단백질과 특정 영양소에 대한 요구가 뚜렷한 동물입니다. 제품이 고양이용인지, 주식으로 설계된 균형 잡힌 제품인지 먼저 확인하는 것이 좋습니다.</p>

          <h2>수분 섭취 환경</h2>
          <p>물그릇 위치, 그릇 재질, 습식 사료 사용 여부 등은 고양이의 일상적인 수분 섭취에 영향을 줄 수 있습니다. 개별 건강 상태에 따라 적절한 방식은 달라질 수 있습니다.</p>

          <h2>간식은 식단의 일부입니다</h2>
          <p>과일처럼 소량 가능한 음식이라도 주식처럼 반복 급여하는 것은 적절하지 않을 수 있습니다. 간식을 줄 때는 다른 간식량을 줄이고, 변 상태와 체중 변화를 함께 확인하세요.</p>

          <div class="warning">본 사이트의 정보는 일반적인 참고용이며, 정확한 진단과 치료는 수의사와 상담하세요.</div>
        </article>
        <aside class="sidebar">
          <div class="card">
            <h3>관련 메뉴</h3>
            <p><a class="card-link" href="/food-label">사료 성분표 읽는 법</a></p>
            <p><a class="card-link" href="/blog">블로그 글 보기</a></p>
          </div>
        </aside>
      </div>
    </section>

    <section class="section alt">
      <div class="container">
        <div class="section-head">
          <h2>고양이 영양 관련 글</h2>
          <p>고양이 보호자가 자주 궁금해하는 간식, 과일, 급여 주의사항을 모았습니다.</p>
        </div>
        {catPosts.length > 0 ? (
          <div class="grid three">
            {catPosts.map((post) => <BlogCard post={post} />)}
          </div>
        ) : (
          <div class="empty-state">아직 등록된 고양이 영양 글이 없습니다.</div>
        )}
      </div>
    </section>
  </main>
</BaseLayout>
