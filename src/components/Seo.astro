---
const {
  title = "Pet Nutrition Guide",
  description = "강아지와 고양이 보호자를 위한 반려동물 영양 정보",
  image = "/pet-nutrition-hero.png",
  path = Astro.url.pathname,
  type = "website",
  headline = title,
  datePublished,
  dateModified,
} = Astro.props;

const siteUrl = "https://mycompanionpet.com";
const normalizePath = (value) => {
  const pathname = value || "/";
  if (pathname === "/" || pathname.includes(".")) return pathname;
  return pathname.endsWith("/") ? pathname : `${pathname}/`;
};
const canonical = new URL(normalizePath(path), siteUrl).toString();
const imageUrl = image?.startsWith("http") ? image : new URL(image, siteUrl).toString();
const articleSchema = type === "article"
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline,
      description,
      image: imageUrl,
      mainEntityOfPage: canonical,
      datePublished,
      dateModified: dateModified || datePublished,
      publisher: {
        "@type": "Organization",
        name: "Pet Nutrition Guide",
        url: siteUrl,
      },
    }
  : null;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
{articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
